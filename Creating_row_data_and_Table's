# Transaction 

CREATE TABLE bank_transaction
(
    transaction_id INT PRIMARY KEY,

    transaction_time DATETIME,

    amount DECIMAL(10,2),

    account_no VARCHAR(15),

    FOREIGN KEY(account_no)
    REFERENCES bank_account(account_no)
);



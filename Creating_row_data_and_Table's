# Employee 

CREATE TABLE employee
(
    employee_id INT PRIMARY KEY,
    employee_name VARCHAR(100),
    employee_contact_number VARCHAR(15),
    employee_gender VARCHAR(10),
    employee_address VARCHAR(200),
    bank_id INT,
    manager_id INT,

    FOREIGN KEY(bank_id)

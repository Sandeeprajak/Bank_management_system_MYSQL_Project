# Bank Account 

CREATE TABLE bank_account
(
    account_no VARCHAR(15) PRIMARY KEY,
    account_type VARCHAR(20),
    balance DECIMAL(10,2),

    bank_id INT,
    customer_id INT,

    FOREIGN KEY(bank_id)
    REFERENCES bank(bank_id),

    FOREIGN KEY(customer_id)
    REFERENCES customer(customer_id)
);


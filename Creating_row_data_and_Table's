Data base creation 

CREATE DATABASE bank_management_system;
USE bank_management_system;

#Bank
CREATE TABLE bank
(
    bank_id INT PRIMARY KEY,
    name VARCHAR(70),
    full_address VARCHAR(200),
    national VARCHAR(50),
    contact VARCHAR(15)
);


